{
  "name": "core",
  "version": "1.0.0",
  "private": true,
  "description": "Parking SaaS - API Backend",
  "type": "module",
  "main": "api/index.js",
  "scripts": {
    "dev": "nodemon src/start.js",
    "start": "node src/start.js",
    "db:reset": "node src/database/scripts/resetDatabase.js",
    "job:subscriptions": "node src/jobs/runSubscriptionScheduler.js",
    "job:backups": "node src/jobs/runBackupScheduler.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:perf": "vitest run tests/performance"
  },
  "imports": {
    "#config/*": "./src/config/*",
    "#database/*": "./src/database/*",
    "#middlewares/*": "./src/middlewares/*",
    "#modules/*": "./src/modules/*",
    "#routes/*": "./src/routes/*",
    "#services/*": "./src/services/*",
    "#utils/*": "./src/utils/*",
    "#app": "./src/app.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.7.4",
    "morgan": "^1.10.1",
    "node-cron": "^4.6.0",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "UNLICENSED"
}
