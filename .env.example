# =============================================================================
# Parking SaaS — Core (API / backend)
# Copiar a .env y completar valores reales. Nunca subir .env al repositorio.
# =============================================================================

# Entorno
NODE_ENV=development
PORT=3000

# Base de datos
# Transacciones (signup/bootstrap) requieren replica set en producción.
# Desarrollo sin Docker/replica set: MONGODB_USE_TRANSACTIONS=false
# Con Docker: docker compose up -d
# Producción (Vercel): MongoDB Atlas URI
MONGODB_URI=mongodb://localhost:27017/parkingsaas
MONGODB_USE_TRANSACTIONS=false
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT=5000

# JWT (en producción: secretos aleatorios >= 32 caracteres)
JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Super Admin (seed al arrancar / primer acceso plataforma)
SUPER_ADMIN_NAME=Super
SUPER_ADMIN_LASTNAME=Admin
SUPER_ADMIN_EMAIL=superadmin@parkingsaas.local
SUPER_ADMIN_PASSWORD=change-this-password-in-production

# Trial inicial (días)
TRIAL_DURATION_DAYS=15

# Motor automático de suscripciones
# En Vercel: node-cron in-process no corre; usar Cron Jobs → /api/internal/cron/*
SUBSCRIPTION_GRACE_PERIOD_DAYS=5
SUBSCRIPTION_SCHEDULER_ENABLED=true
# Cron (UTC): todos los días a las 08:00
SUBSCRIPTION_SCHEDULER_CRON=0 8 * * *
SUBSCRIPTION_REACTIVATION_DAYS=30

# Auditoría — retención en meses (6 | 12 | 24). No elimina automáticamente.
AUDIT_RETENTION_MONTHS=12

# Backups
# En Vercel el disco es efímero: preferir provider externo o desactivar scheduler local
BACKUP_LOCAL_DIR=storage/backups
BACKUP_STORAGE_PROVIDER=local
BACKUP_SCHEDULER_ENABLED=true
BACKUP_SCHEDULER_CRON=5 * * * *

# Aplicación
APP_NAME=Parking SaaS
# Producción Vercel (API):
# APP_URL=https://parking-saas-core.vercel.app
APP_URL=http://localhost:3000
# Frontend (CORS). Preferir FRONTEND_URL.
FRONTEND_URL=http://localhost:5173
# En Vercel core:
# APP_URL=https://parking-saas-core.vercel.app
# FRONTEND_URL=https://parking-saas-client.vercel.app
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none

# Protege GET /api/internal/cron/* (Vercel envía Authorization: Bearer <CRON_SECRET>)
# CRON_SECRET=genera-un-secreto-largo-aleatorio

# Signup — verificación de correo
VERIFICATION_TOKEN_EXPIRES_HOURS=24

# Resend (https://resend.com) — envío real de correos de verificación
# 1) Crea cuenta en Resend → API Keys → Create API Key
# 2) En desarrollo puedes usar: EMAIL_FROM="Parking SaaS <onboarding@resend.dev>"
#    (solo puedes enviar al correo con el que te registraste en Resend)
# 3) En producción: verifica tu dominio y usa noreply@tudominio.com
RESEND_API_KEY=
EMAIL_FROM=Parking SaaS <onboarding@resend.dev>
PRIVACY_POLICY_VERSION=2026-07-16

# Cookies (refresh token HttpOnly)
# En Vercel (client y API en dominios distintos): COOKIE_SECURE=true, COOKIE_SAME_SITE=none
COOKIE_HTTP_ONLY=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/api/auth
# COOKIE_DOMAIN=
ADMIN_COOKIE_PATH=/api/admin/auth

# Rate limiting
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REFRESH_WINDOW_MS=900000
RATE_LIMIT_REFRESH_MAX=60
RATE_LIMIT_SIGNUP_WINDOW_MS=3600000
RATE_LIMIT_SIGNUP_MAX=5
# Techo global API (activar en producción)
RATE_LIMIT_API_ENABLED=false
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=300
