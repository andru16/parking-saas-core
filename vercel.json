{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/internal/cron/subscriptions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/internal/cron/backups",
      "schedule": "0 * * * *"
    }
  ]
}
